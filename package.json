{
  "name": "restcraft",
  "displayName": "RestCraft",
  "description": "Create, manage, and execute API requests from file-based definitions using a Postman-like interface inside Visual Studio Code.",
  "version": "1.2.0",
  "publisher": "nickchecan",
  "icon": "media/icon-gear-clean-transparent.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/nickchecan/restcraft.git"
  },
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "api",
    "http",
    "https",
    "rest",
    "request",
    "testing",
    "postman",
    "client",
    "webview",
    "environment"
  ],
  "activationEvents": [
    "onCustomEditor:restcraft.requestEditor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "restcraft.openApiWorkbench",
        "title": "RestCraft: Open API Workbench"
      },
      {
        "command": "restcraft.loadRequestFile",
        "title": "RestCraft: Load Request File"
      }
    ],
    "customEditors": [
      {
        "viewType": "restcraft.requestEditor",
        "displayName": "RestCraft Request",
        "selector": [
          {
            "filenamePattern": "*.api.json"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vscode-test",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
